<UserControl x:Class="Manitas_WPF_Admin.Views.Modules.ManitasGestionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/TailwindStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════ ENCABEZADO DE MÓDULO ══════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Gestión de Manitas" Style="{StaticResource TextH1}"/>
                    <Border Background="#F0FDF4" CornerRadius="4" Padding="10,3" 
                            Margin="12,0,0,0" VerticalAlignment="Center"
                            BorderBrush="#BBF7D0" BorderThickness="1">
                        <TextBlock Text="274 usuarios" FontSize="11" FontWeight="SemiBold" 
                                   Foreground="#166534"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="Filtra y valida los perfiles de prestadores registrados desde la web." 
                           Style="{StaticResource TextMuted}" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Border Background="{StaticResource BrushWork}" CornerRadius="6" Width="260" Height="36" 
                        BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" Margin="0,0,10,0">
                    <Grid Margin="12,0">
                        <TextBlock Text="Buscar por nombre..." 
                                   VerticalAlignment="Center" 
                                   Foreground="#CBD5E1" 
                                   FontSize="13"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=TxtBuscar}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="TxtBuscar" 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 FontSize="13"
                                 VerticalContentAlignment="Center" 
                                 TextChanged="TxtBuscar_TextChanged"/>
                    </Grid>
                </Border>
                <Button Content="Filtros" Style="{StaticResource BtnGhostLight}" Width="90"/>
            </StackPanel>
        </Grid>

        <!-- ══════════════ TABLA ══════════════ -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
            <DataGrid x:Name="DgManitas" 
                      Style="{StaticResource DataGridPro}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderPro}"
                      RowStyle="{StaticResource DataGridRowPro}"
                      AutoGenerateColumns="False">

                <DataGrid.Columns>

                    <DataGridTemplateColumn Header="USUARIO" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="16,0">
                                    <Border Width="36" Height="36" CornerRadius="18" 
                                            ClipToBounds="True" 
                                            Background="{StaticResource BrushAmbient}">
                                        <Image Source="/Assets/Images/avatar.png" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding NombreCompleto}" 
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource BrushAuthority}"/>
                                        <TextBlock Text="{Binding Correo}" 
                                                   FontSize="11" 
                                                   Foreground="{StaticResource BrushReadText}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="UBICACIÓN" Binding="{Binding Ubicacion}" 
                                        Width="*"
                                        ElementStyle="{StaticResource TextBase}"/>

                    <DataGridTemplateColumn Header="ESTADO" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#FFFBEB" CornerRadius="4" 
                                        HorizontalAlignment="Left" Padding="10,3"
                                        BorderBrush="#FDE68A" BorderThickness="1"
                                        Margin="16,0">
                                    <TextBlock Text="PENDIENTE" FontSize="10" 
                                               FontWeight="SemiBold" Foreground="#92400E"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ACCIONES" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" 
                                            HorizontalAlignment="Center" Margin="0,0">
                                    <Button Style="{StaticResource BtnIcon}" 
                                            Click="BtnVerDetalles_Click"
                                            ToolTip="Ver detalles">
                                        <Path Data="M1,8 C1,8 3,3 8,3 C13,3 15,8 15,8 C15,8 13,13 8,13 C3,13 1,8 1,8 Z M8,6 A2,2 0 1,1 8,10 A2,2 0 1,1 8,6" 
                                              Stroke="{StaticResource BrushReadText}" StrokeThickness="1"
                                              Fill="Transparent" Stretch="Uniform"
                                              Width="14" Height="14"/>
                                    </Button>
                                    <Button Style="{StaticResource BtnIcon}" Margin="4,0,0,0"
                                            ToolTip="Eliminar">
                                        <Path Data="M2,4 L14,4 M5,4 L5,2 L11,2 L11,4 M6,7 L6,12 M10,7 L10,12 M3,4 L4,14 L12,14 L13,4" 
                                              Stroke="{StaticResource BrushAlert}" StrokeThickness="1"
                                              Fill="Transparent" Stretch="Uniform"
                                              Width="13" Height="13"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ══════════════ PANEL LATERAL DE DETALLES ══════════════ -->
        <Border x:Name="PnlDetalles" 
                Grid.Row="0" Grid.RowSpan="2"
                Width="420" HorizontalAlignment="Right"
                Background="{StaticResource BrushWork}"
                BorderBrush="{StaticResource BrushDivider}" 
                BorderThickness="1,0,0,0"
                Visibility="Collapsed">

            <Border.RenderTransform>
                <TranslateTransform x:Name="TransDetalle" X="450"/>
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header del panel -->
                <Border Grid.Row="0" Padding="24,18" 
                        BorderBrush="{StaticResource BrushDivider}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="Detalle del Manita" Style="{StaticResource TextH2}" 
                                   VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Right" Style="{StaticResource BtnGhostLight}"
                                Width="32" Height="32" Padding="0"
                                Click="BtnCerrarDetalle_Click">
                            <Path Data="M3,3 L13,13 M13,3 L3,13" 
                                  Stroke="{StaticResource BrushReadText}" StrokeThickness="1.5"
                                  Stretch="Uniform"
                                  Width="10" Height="10"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Perfil del usuario -->
                <StackPanel Grid.Row="1" Margin="24,20,24,0">
                    <Border Width="64" Height="64" CornerRadius="32" 
                            ClipToBounds="True" HorizontalAlignment="Left"
                            Background="{StaticResource BrushAmbient}">
                        <Image Source="https://i.pravatar.cc/150?u=detail" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock x:Name="DetalleNombre" Text="Nombre del Usuario" 
                               Style="{StaticResource TextH1}" Margin="0,12,0,0"/>
                    <Border Style="{StaticResource BadgeWarning}" Margin="0,8,0,0">
                        <TextBlock Text="PENDIENTE DE VERIFICACIÓN" 
                                   FontSize="10" FontWeight="SemiBold" 
                                   Foreground="#92400E"/>
                    </Border>
                </StackPanel>

                <!-- Contenido del detalle -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,20,0,0">
                    <StackPanel Margin="24,0,24,0">

                        <!-- Separador de sección -->
                        <Border Height="1" Background="{StaticResource BrushDivider}" Margin="0,0,0,16"/>

                        <TextBlock Text="OFICIO Y CATEGORÍA" Style="{StaticResource TextLabel}" Margin="0,0,0,10"/>
                        <Border Background="{StaticResource BrushAmbient}" CornerRadius="6" 
                                Padding="14" Margin="0,0,0,24"
                                BorderBrush="{StaticResource BrushDivider}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="DetalleOficio" Text="Plomero y Fontanero" 
                                           FontSize="15" FontWeight="SemiBold" 
                                           Foreground="{StaticResource BrushAction}"/>
                                <TextBlock Text="Categoría: Mantenimiento del Hogar" 
                                           Style="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="DATOS DE CONTACTO" Style="{StaticResource TextLabel}" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Correo electrónico" Style="{StaticResource TextMuted}" Margin="0,0,0,3"/>
                                <TextBlock x:Name="DetalleCorreo" Text="Cargando..." 
                                           FontWeight="SemiBold" FontSize="13"
                                           Foreground="{StaticResource BrushAuthority}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Ubicación" Style="{StaticResource TextMuted}" Margin="0,0,0,3"/>
                                <TextBlock x:Name="DetalleUbicacion" Text="Cargando..." 
                                           FontWeight="SemiBold" FontSize="13"
                                           Foreground="{StaticResource BrushAuthority}"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

                <!-- Botones de acción -->
                <Border Grid.Row="3" Padding="24,16" 
                        BorderBrush="{StaticResource BrushDivider}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Rechazar" 
                                Style="{StaticResource BtnGhostLight}"
                                Height="40"
                                Foreground="{StaticResource BrushAlert}"/>
                        <Button Grid.Column="2" Content="Aprobar Manita" 
                                Style="{StaticResource BtnPrimary}"
                                Height="40"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</UserControl>