<UserControl x:Class="Manitas_WPF_Admin.Views.Modules.ManitasGestionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/TailwindStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

            <Style x:Key="CenterTextColumn" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="15,0"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Gestión de Manitas" Style="{StaticResource TextH1}"/>
                    <Border Background="#FFF7ED" CornerRadius="4" Padding="10,3" 
                            Margin="12,0,0,0" VerticalAlignment="Center"
                            BorderBrush="#FED7AA" BorderThickness="1">
                        <TextBlock Text="Pendientes de Validación" FontSize="11" FontWeight="SemiBold" 
                                   Foreground="#EA580C"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="Filtra y valida los perfiles registrados desde la plataforma web." 
                           Style="{StaticResource TextMuted}" Margin="0,5,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Border Background="White" CornerRadius="6" Width="300" Height="40" 
                        BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,10">
                    <Grid Margin="12,0">
                        <TextBlock Text=" Buscar por nombre..." 
                                   VerticalAlignment="Center" 
                                   Foreground="#94A3B8" 
                                   FontSize="13"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=TxtBuscar}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="TxtBuscar" 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 FontSize="13"
                                 VerticalContentAlignment="Center" 
                                 TextChanged="TxtBuscar_TextChanged"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColTabla" Width="*"/>
                <ColumnDefinition x:Name="ColSpacer" Width="0"/>
                <ColumnDefinition x:Name="ColDetalle" Width="0"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <DataGrid x:Name="DgManitas" 
                  Style="{StaticResource DataGridPro}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowHeight="70"
                  SelectionChanged="DgManitas_SelectionChanged"
                  BorderThickness="0">
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#F8FAFC"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1E293B"/>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="POSTULANTE" Width="2.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="16,0">
                                        <Border Width="44" Height="44" CornerRadius="22" Background="#F1F5F9" ClipToBounds="True" BorderBrush="#E2E8F0" BorderThickness="1">
                                            <Image Source="{Binding FotoPerfilUrl, TargetNullValue='pack://application:,,,/Manitas_WPF_Admin;component/Assets/Images/no-image.png'}" Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding NombreCompleto}" FontWeight="Bold" FontSize="14" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding Correo}" FontSize="12" Foreground="#64748B"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="OFICIO SOLICITADO" Binding="{Binding OficioNombre}" Width="1.5*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenterTextColumn}">
                                    <Setter Property="FontWeight" Value="ExtraBold"/>
                                    <Setter Property="Foreground" Value="#EA580C"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="ESTADO" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#FFFBEB" CornerRadius="12" Padding="10,4" HorizontalAlignment="Left" Margin="16,0" BorderBrush="#FDE68A" BorderThickness="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="7" Height="7" Fill="#D97706" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="PENDIENTE" FontSize="10" FontWeight="Black" Foreground="#92400E"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="REVISAR" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Click="BtnVerDetalles_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid>
                                                    <Ellipse x:Name="circle" Width="36" Height="36" Fill="Transparent"/>
                                                    <TextBlock Text="👁️" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="circle" Property="Fill" Value="#F1F5F9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border x:Name="PnlDetalles" 
        Grid.Column="2"
        Margin="15,0,0,0"
        Style="{StaticResource Card}"
        Visibility="Collapsed">

                <Border.DataContext>
                    <Binding ElementName="DgManitas" Path="SelectedItem"/>
                </Border.DataContext>

                <Border.RenderTransform>
                    <TranslateTransform x:Name="TransDetalle" X="450"/>
                </Border.RenderTransform>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,15" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Text="Expediente del Manita" FontWeight="Bold" FontSize="16" Foreground="#1E293B"/>
                            <Button HorizontalAlignment="Right" Click="BtnCerrarDetalle_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <TextBlock Text="✕" Foreground="#94A3B8" FontSize="16"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="24">
                            <Border Width="100" Height="100" CornerRadius="50" ClipToBounds="True" HorizontalAlignment="Center"
                        Background="#F1F5F9" BorderBrush="#EA580C" BorderThickness="2" Margin="0,0,0,15">
                                <Image Source="{Binding FotoPerfilUrl, TargetNullValue='pack://application:,,,/Manitas_WPF_Admin;component/Assets/Images/no-image.png'}" Stretch="UniformToFill" VerticalAlignment="Center" 
       HorizontalAlignment="Center" />
                            </Border>

                            <TextBlock Text="{Binding NombreCompleto}" FontSize="18" FontWeight="Black" HorizontalAlignment="Center" TextAlignment="Center"/>

                            <Border CornerRadius="12" Padding="12,3" HorizontalAlignment="Center" Margin="0,8,0,0" 
        BorderBrush="#EA580C" BorderThickness="1" Background="#FFF7ED">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding OficioNombre}" 
                   Foreground="#C2410C" 
                   FontSize="11" 
                   FontWeight="Black" 
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="POSTULANTE A MANITAS" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,5,0,20"/>
                            <Separator Background="#F1F5F9" Margin="0,0,0,20"/>

                            <TextBlock Text="SOLICITUD DE OFICIO" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="8" Padding="15" Margin="0,0,0,24" BorderBrush="#E2E8F0" BorderThickness="1">
                                <TextBlock Text="{Binding OficioDescripcion, FallbackValue='Sin descripción de oficio'}" FontSize="14" Foreground="#1E293B" TextWrapping="Wrap" FontWeight="Medium"/>
                            </Border>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="TELÉFONO" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding Telefono}" FontWeight="Bold" Foreground="#1E293B"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="CORREO" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding Correo}" FontWeight="Bold" Foreground="#1E293B" FontSize="11"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="DOCUMENTACIÓN DE IDENTIDAD (INE)" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,10"/>
                            <UniformGrid Columns="2" Height="110" Margin="0,5,0,15">
                                <Border Margin="0,0,5,0" CornerRadius="6" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <Image Source="{Binding IneFrenteUrl, TargetNullValue='pack://application:,,,/Manitas_WPF_Admin;component/Assets/Images/no-image.png'}" Stretch="Uniform"/>
                                </Border>
                                <Border Margin="5,0,0,0" CornerRadius="6" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <Image Source="{Binding IneReversoUrl, TargetNullValue='pack://application:,,,/Manitas_WPF_Admin;component/Assets/Images/no-image.png'}" Stretch="Uniform"/>
                                </Border>
                            </UniformGrid>

                            <TextBlock Text="COMPROBANTE DE DOMICILIO" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,5"/>
                            <Border Height="140" CornerRadius="6" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                                <Image Source="{Binding DocumentoExtraUrl, TargetNullValue='pack://application:,,,/Manitas_WPF_Admin;component/Assets/Images/no-document.png'}" Stretch="Uniform"/>
                            </Border>

                            <StackPanel x:Name="PnlRechazo" Visibility="Collapsed" Margin="0,20,0,0">
                                <TextBlock Text="MOTIVO DEL RECHAZO" FontSize="10" FontWeight="Bold" Foreground="#EF4444" Margin="0,0,0,8"/>
                                <TextBox x:Name="TxtMotivoRechazo" Height="80" TextWrapping="Wrap" AcceptsReturn="True" BorderBrush="#EF4444"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Padding="20" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="Rechazar" Click="BtnRechazar_Click" 
                Background="#FEE2E2" Foreground="#EF4444" 
                Height="40" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button Grid.Column="2" Content="Aprobar" Click="BtnAprobar_Click" 
                Background="#EA580C" Foreground="White" 
                Height="40" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>