<UserControl x:Class="Manitas_WPF_Admin.Views.Modules.GestionClientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Manitas_WPF_Admin.Views.Modules"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1080">
    <UserControl.Resources>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#F8FAFC"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1E293B"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F8FAFC"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1E293B"/>
            </Style.Resources>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
    </UserControl.Resources>
    <Grid Background="#F8FAFC">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="ColumnExpediente" Width="0"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Margin="25" Background="White" CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Margin="25,25,25,15">
                    <TextBlock Text="Gestión de Clientes" FontSize="22" FontWeight="Black" Foreground="#1E293B"/>
                    <TextBlock Text="Administra y supervisa las cuentas de los usuarios consumidores." Foreground="#64748B" FontSize="12"/>
                </StackPanel>
                <Border Grid.Row="1" 
                    Margin="25,0,25,15" 
                    Background="#F1F5F9" 
                    CornerRadius="8" 
                    Height="40" 
                    MaxWidth="600" 
                    HorizontalAlignment="Left">
                    <Grid>
                        <TextBlock  VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#94A3B8" FontSize="13"/>
                        <TextBlock Text="Buscar por nombre, correo o ID de cliente..." 
                               VerticalAlignment="Center" 
                               Margin="35,0,15,0" 
                               Foreground="#94A3B8" 
                               IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtBusqueda}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="txtBusqueda" 
                             Background="Transparent" 
                             BorderThickness="0" 
                             VerticalContentAlignment="Center" 
                             Margin="32,0,10,0" 
                             FontSize="13"
                             TextChanged="txtBusqueda_TextChanged"/>
                    </Grid>
                </Border>
                <DataGrid x:Name="dgClientes" Grid.Row="2" Margin="15" 
                          AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionChanged="dgClientes_SelectionChanged"
                          Background="Transparent" BorderThickness="0" 
                          RowHeight="50" GridLinesVisibility="None" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="CLIENTE" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                                        <Grid Width="38" Height="38">
                                            <Border Background="#F1F5F9" CornerRadius="19">
                                                <TextBlock Text="{Binding Iniciales}" 
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Center" 
                                   FontSize="12" 
                                   FontWeight="Bold" 
                                   Foreground="#94A3B8"/>
                                            </Border>
                                            <Border CornerRadius="19" ClipToBounds="True">
                                                <Image Source="{Binding FotoPerfilUrl}" Stretch="UniformToFill">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FotoPerfilUrl}" Value="no-image">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding NombreCompleto}" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="CORREO" Binding="{Binding Correo}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="5,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="TELÉFONO" Binding="{Binding Telefono}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="5,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="ESTADO" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F1F5F9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActivo}" Value="True">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Estado}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActivo}" Value="True">
                                                            <Setter Property="Foreground" Value="#166534"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
        <Border Grid.Column="1" x:Name="PanelExpediente" Margin="0,25,25,25" Background="White" CornerRadius="16" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Button Content="✕" HorizontalAlignment="Right" Margin="15" Background="Transparent" BorderThickness="0" Click="BtnCerrarPanel_Click"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="25,0,25,25">
                        <Grid Width="90" Height="90" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <Border Background="#F1F5F9" CornerRadius="45">
                                <TextBlock Text="{Binding Iniciales}" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="#94A3B8"/>
                            </Border>
                            <Border CornerRadius="45" ClipToBounds="True" BorderBrush="#F1F5F9" BorderThickness="3">
                                <Image Source="{Binding FotoPerfilUrl}" Stretch="UniformToFill">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FotoPerfilUrl}" Value="no-image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FotoPerfilUrl}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding NombreCompleto}" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" TextAlignment="Center" Foreground="#1E293B"/>
                        <TextBlock Text="PERFIL CLIENTE" Foreground="#94A3B8" FontSize="10" 
                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,25"/>
                        <Separator Background="#F1F5F9" Margin="0,0,0,20"/>
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="CORREO" FontSize="10" Foreground="#94A3B8" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Correo}" FontSize="13" Foreground="#1E293B" Margin="0,2"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="TELÉFONO" FontSize="10" Foreground="#94A3B8" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Telefono}" FontSize="13" Foreground="#1E293B" Margin="0,2"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="REGISTRADO EL" FontSize="10" Foreground="#94A3B8" FontWeight="Bold"/>
                            <TextBlock Text="{Binding FechaRegistro, StringFormat=\{0:dd/MM/yyyy\}}" FontSize="13" Foreground="#1E293B" Margin="0,2"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                <Border Grid.Row="2" Padding="20" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0">
                    <Button x:Name="btnToggleEstado" Height="40" FontWeight="Bold" BorderThickness="0" Click="BtnCambiarEstado_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="Desactivar Cuenta"/>
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="Foreground" Value="#EF4444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActivo}" Value="False">
                                        <Setter Property="Content" Value="Reactivar Cuenta"/>
                                        <Setter Property="Background" Value="#DCFCE7"/>
                                        <Setter Property="Foreground" Value="#166534"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>