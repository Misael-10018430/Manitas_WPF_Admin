<UserControl x:Class="Manitas_WPF_Admin.Views.Modules.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:Manitas_WPF_Admin.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/TailwindStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="CenterTextColumn" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="15,0"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,20">
            <Grid Margin="0,0,0,20">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Resumen de Operaciones" Style="{StaticResource TextH1}"/>
                    <TextBlock Text="Indicadores clave del sistema en tiempo real" 
                               Style="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
            <Border Background="White" CornerRadius="16" Margin="0,0,0,25" Padding="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" VerticalAlignment="Center">
                        <Ellipse Stroke="#F1F5F9" StrokeThickness="18" Width="160" Height="160"/>
                        <Ellipse x:Name="PieManitas" Stroke="#FFEDD5" StrokeThickness="18" Width="160" Height="160" 
                                 StrokeDashArray="70,30" StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse x:Name="PieClientes" Stroke="#E0F2FE" StrokeThickness="18" Width="160" Height="160" 
                                 StrokeDashArray="30,70" StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="160"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="TOTAL" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtTotalUsuarios" Text="164" FontSize="32" FontWeight="ExtraBold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                            <TextBlock Text="Miembros" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <UniformGrid Grid.Column="1" Columns="2" Rows="2" Margin="20,0,0,0">
                        <Border Background="#FFFBEB" CornerRadius="12" Margin="6" Padding="14"
                        Cursor="Hand" 
                        MouseDown="BtnVerPendientes_Click"> 
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="PENDIENTES" FontSize="9" FontWeight="Bold" Foreground="#B45309" Opacity="0.8"/>
                                <TextBlock x:Name="TxtPendientes" Text="8" FontSize="22" FontWeight="Bold" Foreground="#92400E" Margin="0,2"/>
                                <TextBlock Text="Revisión requerida" FontSize="10" Foreground="#D97706"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F0FDF4" CornerRadius="12" Margin="6" Padding="14">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="SERVICIOS" FontSize="9" FontWeight="Bold" Foreground="#15803D" Opacity="0.8"/>
                                <TextBlock x:Name="TxtActivos" Text="32" FontSize="22" FontWeight="Bold" Foreground="#166534" Margin="0,2"/>
                                <TextBlock Text="En tiempo real" FontSize="10" Foreground="#16A34A"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FEF2F2" CornerRadius="12" Margin="6" Padding="14">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="DISPUTAS" FontSize="9" FontWeight="Bold" Foreground="#B91C1C" Opacity="0.8"/>
                                <TextBlock x:Name="TxtDisputas" Text="2" FontSize="22" FontWeight="Bold" Foreground="#991B1B" Margin="0,2"/>
                                <TextBlock Text="Casos abiertos" FontSize="10" Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F5F3FF" CornerRadius="12" Margin="6" Padding="14">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="INGRESOS" FontSize="9" FontWeight="Bold" Foreground="#6D28D9" Opacity="0.8"/>
                                <TextBlock x:Name="TxtIngresos" Text="$15,420" FontSize="22" FontWeight="Bold" Foreground="#6B21A8" Margin="0,2"/>
                                <TextBlock Text="Corte del mes" FontSize="10" Foreground="#7C3AED"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>
            <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True" MaxHeight="380" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="24,20,24,0">
                        <StackPanel>
                            <TextBlock Text="Actividad Reciente" Style="{StaticResource TextH2}"/>
                            <TextBlock Text="Miembros activos actualmente en el sistema" 
                                       Style="{StaticResource TextMuted}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="0" Height="1" Background="{StaticResource BrushDivider}" VerticalAlignment="Bottom" Margin="0,60,0,0"/>
                    <Grid Grid.Row="1" Margin="0,15,0,0">
                        <DataGrid x:Name="DgActividad" 
                          Style="{StaticResource DataGridPro}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          BorderThickness="0"
                          Background="Transparent"
                          RowHeight="55"
                          ScrollViewer.VerticalScrollBarVisibility="Hidden" 
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.CanContentScroll="False"
                          EnableRowVirtualization="True"
                          VirtualizingStackPanel.IsVirtualizing="True">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="MIEMBRO" Width="2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                                <Grid Width="34" Height="34">
                                                    <Border Background="#F1F5F9" CornerRadius="17">
                                                        <TextBlock Text="{Binding Iniciales}" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center" 
                                           FontSize="11" 
                                           FontWeight="Bold" 
                                           Foreground="#94A3B8"/>
                                                    </Border>
                                                    <Border CornerRadius="17" ClipToBounds="True">
                                                        <Image Source="{Binding FotoPerfilUrl}" Stretch="UniformToFill">
                                                            <Image.Style>
                                                                <Style TargetType="Image">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding FotoPerfilUrl}" Value="no-image">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                        </Image>
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding NombreCompleto}" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#1E293B"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="ROL" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding RolNombre, Converter={StaticResource RolToColorConverter}}" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding RolNombre}" FontSize="10" FontWeight="Bold" Foreground="#1E293B"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="TELÉFONO" Binding="{Binding Telefono}" Width="1.2*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="10,0,0,0"/>
                                            <Setter Property="Foreground" Value="#64748B"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="ESTADO" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8" Fill="{Binding EstadoColor}" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding EstadoTexto}" FontSize="11" Foreground="#64748B"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>