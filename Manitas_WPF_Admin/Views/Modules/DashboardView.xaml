<UserControl x:Class="Manitas_WPF_Admin.Views.Modules.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/TailwindStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <StackPanel Margin="0,0,0,20">

            <Grid Margin="0,0,0,20">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Resumen de Operaciones" Style="{StaticResource TextH1}"/>
                    <TextBlock Text="Indicadores clave del sistema en tiempo real" 
                               Style="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
            <UniformGrid Columns="3" Margin="0,0,0,4">
                <Border Style="{StaticResource CardStat}" Margin="0,0,16,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="Total Manitas" Style="{StaticResource TextMuted}"/>
                            <Border HorizontalAlignment="Right" Width="36" Height="36" 
                                    CornerRadius="6" Background="#F0FDF4">
                                <Path Data="M10,5 A3,3 0 1,1 4,5 A3,3 0 1,1 10,5 M1,15 C1,11 3,9 7,9 C11,9 13,11 13,15 M11,7 L15,7 M13,5 L13,9" 
                                      Stroke="#22C55E" StrokeThickness="1.2" 
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtManitasActivos" Grid.Row="1" Text="5,423" 
                                   Style="{StaticResource TextKpiValue}" Margin="0,8,0,4"/>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="↑ 16%" Foreground="{StaticResource BrushSuccess}" 
                                       FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Text=" este mes" Style="{StaticResource TextMuted}" 
                                       FontSize="12" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Style="{StaticResource CardStat}" Margin="0,0,16,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="Pendientes" Style="{StaticResource TextMuted}"/>
                            <Border HorizontalAlignment="Right" Width="36" Height="36" 
                                    CornerRadius="6" Background="#FFFBEB">
                                <Path Data="M8,1 L8,9 M8,11 L8,13" 
                                      Stroke="#F59E0B" StrokeThickness="1.5" 
                                      Stretch="Uniform"
                                      Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtSolicitudes" Grid.Row="1" Text="189" 
                                   Style="{StaticResource TextKpiValue}" Margin="0,8,0,4"/>
                        <TextBlock Grid.Row="2" Text="Revisión requerida" 
                                   Foreground="{StaticResource BrushPending}" 
                                   FontSize="12" FontWeight="SemiBold"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource CardStat}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="Servicios Activos" Style="{StaticResource TextMuted}"/>
                            <Border HorizontalAlignment="Right" Width="36" Height="36" 
                                    CornerRadius="6" Background="#EFF6FF">
                                <Path Data="M3,12 L6,9 L9,11 L14,4" 
                                      Stroke="#3B82F6" StrokeThickness="1.5" 
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtEnCurso" Grid.Row="1" Text="32" 
                                   Style="{StaticResource TextKpiValue}" Margin="0,8,0,4"/>
                        <TextBlock Grid.Row="2" Text="En tiempo real" 
                                   Style="{StaticResource TextMuted}" FontSize="12"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource CardStat}" Margin="0,0,16,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="Disputas" Style="{StaticResource TextMuted}"/>
                            <Border HorizontalAlignment="Right" Width="36" Height="36" 
                                    CornerRadius="6" Background="#FEF2F2">
                                <Path Data="M8,2 L14,14 L2,14 Z M8,7 L8,10 M8,11.5 L8,12.5" 
                                      Stroke="#EF4444" StrokeThickness="1.2" 
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtDisputas" Grid.Row="1" Text="2" 
                                   Style="{StaticResource TextKpiValue}" 
                                   Foreground="{StaticResource BrushAlert}" Margin="0,8,0,4"/>
                        <TextBlock Grid.Row="2" Text="↓ 1% vs ayer" 
                                   Foreground="{StaticResource BrushAlert}" 
                                   FontSize="12" FontWeight="SemiBold"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource CardStat}" Margin="0,0,16,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="Ingresos Totales" Style="{StaticResource TextMuted}"/>
                            <Border HorizontalAlignment="Right" Width="36" Height="36" 
                                    CornerRadius="6" Background="#FFF5F2">
                                <Path Data="M8,2 L8,4 M8,12 L8,14 M5,5 L8,4 L11,5 L12,8 L9,9 L6,10 L5,12 L8,13 L11,12" 
                                      Stroke="{StaticResource BrushAction}" 
                                      StrokeThickness="1.2" 
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="TxtComisiones" Grid.Row="1" Text="$15,420" 
                                   Style="{StaticResource TextKpiValue}" Margin="0,8,0,4"/>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="↑ 8%" Foreground="{StaticResource BrushSuccess}" 
                                       FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Text=" este mes" Style="{StaticResource TextMuted}" 
                                       FontSize="12" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>
            <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True" MinHeight="420">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="24,20,24,0">
                        <StackPanel>
                            <TextBlock Text="Actividad Reciente" Style="{StaticResource TextH2}"/>
                            <TextBlock Text="Miembros activos actualmente en el sistema" 
                                       Style="{StaticResource TextMuted}" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="{StaticResource BrushAmbient}" CornerRadius="6" 
                                Width="200" Height="34"
                                BorderBrush="{StaticResource BrushDivider}" BorderThickness="1">
                            <Grid Margin="12,0">
                                <TextBlock Text="Buscar..." VerticalAlignment="Center" 
                                           Foreground="#CBD5E1" FontSize="12"
                                           IsHitTestVisible="False"/>
                                <TextBox Background="Transparent" BorderThickness="0" 
                                         Margin="0,0,0,0" Width="160" FontSize="12"
                                         VerticalContentAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                    <Border Grid.Row="0" Height="1" Background="{StaticResource BrushDivider}" 
                            VerticalAlignment="Bottom" Margin="0,60,0,0"/>
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" 
                                HorizontalAlignment="Center" Margin="0,40">
                        <Border Width="48" Height="48" CornerRadius="24" 
                                Background="{StaticResource BrushAmbient}"
                                HorizontalAlignment="Center">
                            <Path Data="M6,3 L14,3 L14,13 L6,13 Z M4,5 L2,5 L2,15 L12,15 L12,13 M8,7 L12,7 M8,10 L12,10" 
                                  Stroke="{StaticResource BrushReadText}" StrokeThickness="1"
                                  Fill="Transparent" Stretch="Uniform"
                                  Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Consultando transacciones en SQL Server..." 
                                   Style="{StaticResource TextMuted}" 
                                   Margin="0,12,0,0" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>