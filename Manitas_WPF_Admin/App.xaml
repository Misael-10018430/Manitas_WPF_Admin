<Application x:Class="Manitas_WPF_Admin.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Manitas_WPF_Admin.Converters"
             StartupUri="Views/Account/LoginView.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/TailwindStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:RolToColorConverter x:Key="RolToColorConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>